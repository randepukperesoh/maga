{
  "name": "rod-system-designer",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:training": "pnpm --filter training-dashboard dev",
    "dev:local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev-local.ps1",
    "dev:local:web-only": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev-local.ps1 -SkipTrainingDashboard",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:js": "eslint apps/web/src apps/training-dashboard/src --ext .ts,.tsx",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\" \"packages/**/*.{ts,tsx,js,jsx,json,md}\" \"agent docs/**/*.md\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\" \"packages/**/*.{ts,tsx,js,jsx,json,md}\" \"agent docs/**/*.md\"",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.29.1"
  }
}
